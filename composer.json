{
    "name": "casamento/rbac",
    "description": "Module + role + permission management package — extracted from casamento, reusable across Laravel projects.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "spatie/laravel-permission": "^6.24"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Casamento\\Rbac\\": "src/",
            "Casamento\\Rbac\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Casamento\\Rbac\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Casamento\\Rbac\\RbacServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
