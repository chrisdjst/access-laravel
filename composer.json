{
    "name": "modularize-rbac/laravel",
    "description": "Laravel bridge for modularize-rbac/core: Eloquent repositories, HTTP controllers, migrations, and optional Spatie permissions adapter.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rbac",
        "permissions",
        "roles",
        "modules",
        "access-control",
        "i18n",
        "spatie"
    ],
    "authors": [
        {
            "name": "Christopher",
            "email": "christophertheilacher@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/chrisdjst/access-laravel/issues",
        "source": "https://github.com/chrisdjst/access-laravel",
        "docs": "https://github.com/chrisdjst/access-laravel#readme",
        "chat": "https://github.com/chrisdjst/access-laravel/discussions"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/chrisdjst"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "modularize-rbac/core": "^1.6"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.8",
        "spatie/laravel-permission": "^6.24"
    },
    "suggest": {
        "spatie/laravel-permission": "^6.0 — opt-in adapter that mirrors permissions into Spatie's `role_has_permissions` pivot so hosts using the HasRoles trait keep working with `$user->can()`. Enable via `config('access.spatie.enabled')`."
    },
    "autoload": {
        "psr-4": {
            "ModularizeRbac\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ModularizeRbac\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ModularizeRbac\\Laravel\\AccessServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
