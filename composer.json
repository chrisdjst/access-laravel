{
    "name": "modularize/access-laravel",
    "description": "Laravel bridge for modularize/access-core: Eloquent repositories, HTTP controllers, migrations, and optional Spatie permissions adapter.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rbac",
        "permissions",
        "roles",
        "modules",
        "access-control",
        "i18n",
        "spatie"
    ],
    "authors": [
        {
            "name": "Christopher",
            "email": "christophertheilacher@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/chrisdjst/access-laravel/issues",
        "source": "https://github.com/chrisdjst/access-laravel"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "spatie/laravel-permission": "^6.24"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Modularize\\Access\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modularize\\Access\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modularize\\Access\\Laravel\\AccessServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
