{
  "name": "@modularize-rbac/admin-react",
  "version": "0.1.0",
  "private": false,
  "description": "React hooks + Storybook-driven admin components for modularize-rbac/laravel.",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
