{
    "$schema": "./vendor/phpbench/phpbench/phpbench.schema.json",
    "runner.bootstrap": "benchmarks/bootstrap.php",
    "runner.path": "benchmarks",
    "runner.file_pattern": "*Bench.php",
    "runner.iterations": 3,
    "runner.revs": 5,
    "runner.warmup": 1,
    "runner.retry_threshold": 5,
    "report.outputs": {
        "markdown": {
            "renderer": "delimited",
            "delimiter": " | "
        }
    }
}
