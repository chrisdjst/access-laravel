{
  "name": "@modularize-rbac/sdk-ts",
  "version": "0.1.0",
  "description": "TypeScript SDK for modularize-rbac/laravel — generated from openapi.json.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build": "npm run generate && tsc -p tsconfig.build.json && node scripts/copy-types.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisdjst/access-laravel.git",
    "directory": "sdk-ts"
  },
  "keywords": [
    "rbac",
    "openapi",
    "sdk",
    "typescript",
    "modularize-rbac"
  ]
}
